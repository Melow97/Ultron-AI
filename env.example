# Copy this file to .env.local for local development (vite dev picks it up automatically).
# In production, set this in Vercel: Project Settings > Environment Variables.
# Never commit your real key — .env.local is already in .gitignore.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe — Pro plan checkout and webhook
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_PRICE_ID_PRO=price_your-pro-plan-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
